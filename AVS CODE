@app.route('/person_follow')
def person_follow():
    global mode
    mode = "person_follow"
    return "PERSON FOLLOW MODE"

@app.route('/obstacle_avoid')
def obstacle_avoid():
    global mode
    mode = "obstacle_avoid"
    return "OBSTACLE AVOID MODE"
    
@app.route('/red_follow')
def red_follow():
    global mode
    mode = "red_follow"
    return "RED FOLLOW MODE"

@app.route('/line_follow')
def line_follow():
    global mode
    mode = "line_follow"
    return "LINE FOLLOW MODE"

@app.route('/manual')
def manual_mode():
